# Path to a Netscape-format cookies.txt exported from your browser (needed for
# private/login-gated Instagram content). Leave unset for public content only.
COOKIES_FILE=

# "auto" picks the best model for your hardware (large-v3 on CUDA, large-v3-turbo
# on CPU/Apple Silicon). Override with a specific faster-whisper model name.
MODEL_SIZE=auto

# "auto" detects CUDA vs CPU. Override with "cpu" or "cuda".
DEVICE=auto

# "auto" picks float16 on CUDA, int8 on CPU. Override with a CTranslate2 compute type.
COMPUTE_TYPE=auto

API_PORT=8000
WEB_PORT=5173
